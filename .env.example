# Instagram Downloader API - Environment Variables
# Vercel pe bhi yahi variables set karne honge

# API Security Key (apna khud ka secret key rakho)
API_KEY=your_secret_api_key_here

# Optional: RapidAPI key (backup scraper ke liye)
RAPIDAPI_KEY=your_rapidapi_key_here

# Instagram Session Cookie (agar private content chahiye)
# Instagram par login karke, browser dev tools se nikalo
INSTAGRAM_SESSION_ID=your_instagram_session_id_here
